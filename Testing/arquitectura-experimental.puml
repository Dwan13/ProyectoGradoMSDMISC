@startuml
!theme spacelab

' =========================
' Visual Style
' =========================

skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam ArrowThickness 1.5
skinparam packageStyle rectangle
skinparam componentStyle rectangle

skinparam package {
    BackgroundColor #DCEAFE
    BorderColor #1D4ED8
    FontColor #111827
    FontStyle bold
}

skinparam component {
    BackgroundColor #FFFFFF
    BorderColor #111827
    FontColor #111827
    FontStyle bold
}

skinparam database {
    BackgroundColor #FEF3C7
    BorderColor #D97706
    FontColor #78350F
    FontStyle bold
}

skinparam actor {
    BackgroundColor #DCFCE7
    BorderColor #15803D
    FontColor #14532D
    FontStyle bold
}

skinparam arrow {
    Color #111827
}

title <size:22><b>Experimental Microservices Architecture</b></size>

actor "k6 Load Generator" as User

package "Kubernetes Cluster" {

    package "Security Layer" {
        [Istio Ingress]
        [Kong Gateway]
        [NGINX Gateway]
        [Linkerd mTLS]
    }

    package "Application Namespace: realistic" {

        [api-service]
        [auth-service]
        [data-service]

        database "PostgreSQL" as DB
    }

    package "Monitoring Stack" {
        [Prometheus]
        [Grafana]
    }
}

' =========================
' Traffic Flow
' =========================

User --> [Istio Ingress]
User --> [Kong Gateway]
User --> [NGINX Gateway]
User --> [Linkerd mTLS]

' =========================
' Internal Communication
' =========================

[Istio Ingress] --> [api-service]
[Kong Gateway] --> [api-service]
[NGINX Gateway] --> [api-service]
[Linkerd mTLS] --> [api-service]

[api-service] --> [auth-service]
[api-service] --> [data-service]
[data-service] --> DB

' =========================
' Monitoring
' =========================

[Prometheus] ..> [api-service] : metrics
[Grafana] ..> [Prometheus]

@enduml