@startuml arquitectura_mubench_s2
!theme plain
skinparam backgroundColor #FEFEFE
skinparam componentStyle rectangle
skinparam defaultFontSize 11
skinparam arrowFontSize 10

title "muBench S2 — Arquitectura del Experimento (Baseline Legítimo)\n(MicroK8s Single-Node, namespace: mubench-real)"

'=== ACTOR EXTERNO ===
actor "k6\nLoad Generator" as k6 #LightBlue
note right of k6
  SECURITY_MODE=normal
  VUS=1,5,10,20
  Duration=60s
  Flujo: login → profile → users
end note

'=== CAPA DE INGRESS ===
package "Ingress Layer (C1 — API Gateway)" {
  [NGINX Ingress\n(C1/baseline)] as nginx #PaleTurquoise
  [Istio IngressGateway\n(C1/istio)] as istio_gw #PaleTurquoise
  [Kong Ingress\n(C1/kong)] as kong_gw #PaleTurquoise
}

'=== CAPA DE MICROSERVICIOS (mubench-real) ===
package "namespace: mubench-real" {

  package "mTLS Layer (C2)" {
    [auth-service\n:8080\n/auth/login] as auth #LightGreen
    [api-service\n:8080\n/api/profile\n/api/users] as api #LightGreen
    [data-service\n:8080\n/data/...] as data #LightGreen
  }

  database "PostgreSQL\n:5432" as postgres #Wheat

  package "Network Policy (C3)" {
    note as np_note
      basic:  data-service ← api-service only
      strict: api-service egress ONLY DNS
    end note
  }

  package "Rate Limiter (C4)" {
    [Gateway Config\nmoderate: 1200 rpm\nstrict: 300 rpm] as rl #LightYellow
  }
}

'=== OBSERVABILITY ===
package "namespace: observability" {
  [Prometheus\nv2.47+] as prom #LightCoral
  [Grafana\nv10+] as grafana #LightCoral
  [node-exporter\ncAdvisor] as exporters #LightCoral
}

'=== ANÁLISIS ===
package "Analysis Pipeline (host)" {
  [analyze_k6_results.py\n(ANOVA)] as analysis #LightGray
  [NDJSON Results\n(634 files S2)] as ndjson #LightGray
  [CSV Consolidado\n(48 celdas × 8 réplicas)] as csv #LightGray
}

'=== FLUJO DE TRÁFICO LEGÍTIMO ===
k6 --> nginx : HTTPS POST /auth/login\nHTTPS GET /api/profile\nHTTPS GET /api/users
k6 --> istio_gw : (C1/istio variant)
k6 --> kong_gw : (C1/kong variant)

nginx --> auth : POST /login → JWT
nginx --> api : GET /profile\nGET /users
istio_gw --> auth
istio_gw --> api
kong_gw --> auth
kong_gw --> api

auth --> api : JWT validation
api --> data : GET /data/profile\nGET /data/users
data --> postgres : SQL queries\n(port 5432)

'=== FLUJO DE MÉTRICAS ===
auth ..> prom : /metrics (scrape 10s)
api ..> prom : /metrics (scrape 10s)
data ..> prom : /metrics (scrape 10s)
exporters ..> prom : node/cAdvisor metrics (15s)
prom --> grafana : Query / Dashboard
k6 --> ndjson : NDJSON output\nper-run file
ndjson --> analysis : parse + ANOVA
prom --> analysis : PromQL (cpu_mcores, mem_mib)
analysis --> csv : avg_ms, p95_ms, err_pct,\nrps, cpu_mcores, mem_mib

'=== LEYENDA mTLS (C2) ===
note bottom of auth
  C2/istio-mtls: Envoy sidecar (STRICT PeerAuthentication)
  C2/linkerd-mtls: linkerd-proxy (automatic mTLS)
  C2/baseline: plaintext inter-service traffic
end note

@enduml
