@startuml
' Diseño experimental muBench (B1-B8, 8 réplicas por celda)

actor "Investigador" as user
rectangle "Design Matrix" as matrix
rectangle "k6 Benchmarks" as k6
rectangle "Prometheus Metrics" as prometheus
rectangle "Post-processing" as post
rectangle "Statistical Analysis" as stats

user --> matrix : Define controles, variantes, VUs
matrix --> k6 : Ejecuta experimentos (B1-B8)
k6 --> prometheus : Genera métricas (k6, Prometheus)
prometheus --> post : Exporta métricas
k6 --> post : Exporta resultados
post --> stats : Fusiona y analiza datos
stats --> user : Reporte final (ANOVA, TOST, solidness)
@enduml
